---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

const footerServices = [
	{ href: `/${lang}/services/electricite`, label: t('service.electricite') },
	{ href: `/${lang}/services/plomberie`, label: t('service.plomberie') },
	{ href: `/${lang}/services/carrelage`, label: t('service.carrelage') },
	{ href: `/${lang}/services/parquet`, label: t('service.parquet') },
	{ href: `/${lang}/services/peinture`, label: t('service.peinture') },
	{ href: `/${lang}/services/poncage`, label: t('service.poncage') },
];

const footerLinks = [
	{ href: `/${lang}/`, label: t('nav.home') },
	{ href: `/${lang}/services`, label: t('nav.services') },
	{ href: `/${lang}/about`, label: t('nav.about') },
	{ href: `/${lang}/gallery`, label: t('nav.gallery') },
	{ href: `/${lang}/contact`, label: t('nav.contact') },
];
---

<footer class="bg-deb-white text-deb-dark relative overflow-hidden border-t border-deb-border">
	<!-- Top decorative line -->
	<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-deb-gold to-transparent" />
	
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<!-- Main footer content -->
		<div class="py-20 lg:py-24 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
			<!-- Company info - spans 5 columns -->
			<div class="lg:col-span-5">
				<div class="flex items-center gap-4 mb-8">
					<div class="relative h-16 w-auto">
						<img 
							src="/images/logo.png" 
							alt="D.E.B TOUT CORPS" 
							class="h-full w-auto object-contain"
							width="200"
							height="64"
						/>
					</div>
				</div>
				<p class="text-deb-gray-light text-sm leading-relaxed mb-8 max-w-sm">{t('footer.desc')}</p>
				
				<!-- Social icons -->
				<div class="flex items-center gap-3">
					<a 
						href="#" 
						class="w-10 h-10 rounded-full bg-deb-cream border border-deb-border flex items-center justify-center hover:bg-deb-gold hover:border-deb-gold hover:text-deb-dark transition-all duration-500 group"
						aria-label="Facebook"
					>
						<svg class="w-4 h-4 text-deb-gray group-hover:text-deb-dark transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
					</a>
					<a 
						href="#" 
						class="w-10 h-10 rounded-full bg-deb-cream border border-deb-border flex items-center justify-center hover:bg-deb-gold hover:border-deb-gold hover:text-deb-dark transition-all duration-500 group"
						aria-label="Instagram"
					>
						<svg class="w-4 h-4 text-deb-gray group-hover:text-deb-dark transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
					</a>
					<a 
						href="#" 
						class="w-10 h-10 rounded-full bg-deb-cream border border-deb-border flex items-center justify-center hover:bg-deb-gold hover:border-deb-gold hover:text-deb-dark transition-all duration-500 group"
						aria-label="LinkedIn"
					>
						<svg class="w-4 h-4 text-deb-gray group-hover:text-deb-dark transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					</a>
				</div>
			</div>
			
			<!-- Services -->
			<div class="lg:col-span-3 lg:col-start-7">
				<h3 class="text-deb-dark font-semibold mb-6 text-sm uppercase tracking-[0.15em]">{t('footer.services')}</h3>
				<ul class="space-y-4">
					{footerServices.map((service) => (
						<li>
							<a href={service.href} class="group flex items-center text-deb-gray hover:text-deb-gold transition-all duration-300 text-sm">
								<span class="w-0 group-hover:w-4 h-[1px] bg-deb-gold mr-0 group-hover:mr-2 transition-all duration-300"></span>
								{service.label}
							</a>
						</li>
					))}
				</ul>
			</div>
			
			<!-- Contact -->
			<div class="lg:col-span-4">
				<h3 class="text-deb-dark font-semibold mb-6 text-sm uppercase tracking-[0.15em]">{t('footer.contact')}</h3>
				<ul class="space-y-5">
					<li class="flex items-start gap-4 group">
						<div class="w-10 h-10 rounded-lg bg-deb-cream border border-deb-border flex items-center justify-center flex-shrink-0 group-hover:bg-deb-gold/10 group-hover:border-deb-gold/30 transition-all duration-300">
							<svg class="w-4 h-4 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
						</div>
						<div>
							<p class="text-deb-gray-light text-xs uppercase tracking-wider mb-1">{t('footer.phone')}</p>
							<p class="text-deb-dark text-sm font-medium">+33 1 23 45 67 89</p>
						</div>
					</li>
					<li class="flex items-start gap-4 group">
						<div class="w-10 h-10 rounded-lg bg-deb-cream border border-deb-border flex items-center justify-center flex-shrink-0 group-hover:bg-deb-gold/10 group-hover:border-deb-gold/30 transition-all duration-300">
							<svg class="w-4 h-4 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
						</div>
						<div>
							<p class="text-deb-gray-light text-xs uppercase tracking-wider mb-1">{t('footer.email')}</p>
							<p class="text-deb-dark text-sm font-medium">contact@deb-toutcorps.fr</p>
						</div>
					</li>
					<li class="flex items-start gap-4 group">
						<div class="w-10 h-10 rounded-lg bg-deb-cream border border-deb-border flex items-center justify-center flex-shrink-0 group-hover:bg-deb-gold/10 group-hover:border-deb-gold/30 transition-all duration-300">
							<svg class="w-4 h-4 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
						</div>
						<div>
							<p class="text-deb-gray-light text-xs uppercase tracking-wider mb-1">{t('footer.address')}</p>
							<p class="text-deb-dark text-sm font-medium">{t('footer.addressValue')}</p>
						</div>
					</li>
				</ul>
			</div>
		</div>
		
		<!-- Bottom bar -->
		<div class="py-8 border-t border-deb-border flex flex-col sm:flex-row items-center justify-between gap-4">
			<p class="text-deb-gray text-sm">
				© {currentYear} D.E.B TOUT CORPS. {t('footer.rights')}
			</p>
			<div class="flex items-center gap-8">
				<a href="#" class="text-deb-gray hover:text-deb-gold text-sm transition-colors duration-300">{t('footer.legal')}</a>
				<a href="#" class="text-deb-gray hover:text-deb-gold text-sm transition-colors duration-300">{t('footer.privacy')}</a>
			</div>
		</div>
	</div>
</footer>
