---
interface Props {
	eyebrow: string;
	title: string;
	description?: string;
	centered?: boolean;
	light?: boolean;
	class?: string;
}

const { eyebrow, title, description, centered = true, light = false, class: className = '' } = Astro.props;
---

<div class={`max-w-3xl ${centered ? 'mx-auto text-center' : ''} mb-16 lg:mb-20 ${className}`}>
	<div class={`flex items-center gap-3 mb-6 ${centered ? 'justify-center' : ''}`}>
		{!centered && <span class="w-12 h-[2px] bg-deb-gold rounded-full"></span>}
		<span class={`text-sm font-semibold tracking-[0.2em] uppercase ${light ? 'text-deb-gold' : 'text-deb-gold'}`}>
			{eyebrow}
		</span>
		{centered && <span class="w-12 h-[2px] bg-deb-gold rounded-full"></span>}
	</div>
	
	<h2 class={`text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold tracking-tight mb-6 leading-[1.1] ${light ? 'text-deb-white' : 'text-deb-dark'}`}>
		{title}
	</h2>
	
	{description && (
		<p class={`text-lg leading-relaxed max-w-2xl ${centered ? 'mx-auto' : ''} ${light ? 'text-deb-white/60' : 'text-deb-gray-light'}`}>
			{description}
		</p>
	)}
</div>
