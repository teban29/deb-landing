---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
	service: string;
	icon: string;
}

const { service, icon } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const icons: Record<string, string> = {
	electricite: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
	plomberie: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06 1.06l1.591-1.591a.75.75 0 00-1.061-1.06l-1.59 1.591z"/>',
	carrelage: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>',
	parquet: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.375 6h17.25M3.375 12h17.25M3.375 18h17.25"/>',
	peinture: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.077-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>',
	poncage: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>'
};

const serviceColors: Record<string, string> = {
	electricite: 'from-amber-500/10 to-yellow-500/10',
	plomberie: 'from-blue-500/10 to-cyan-500/10',
	carrelage: 'from-stone-500/10 to-orange-500/10',
	parquet: 'from-amber-700/10 to-yellow-600/10',
	peinture: 'from-rose-500/10 to-pink-500/10',
	poncage: 'from-orange-500/10 to-red-500/10',
};
---

<a 
	href={`/${lang}/services/${service}`}
	class="group relative bg-deb-white rounded-2xl p-8 lg:p-10 border border-deb-border/50 hover:border-deb-gold/30 transition-all duration-700 hover-lift overflow-hidden"
>
	<!-- Background gradient on hover -->
	<div class={`absolute inset-0 bg-gradient-to-br ${serviceColors[service]} opacity-0 group-hover:opacity-100 transition-opacity duration-700`} />
	
	<!-- Decorative corner accent -->
	<div class="absolute top-0 right-0 w-24 h-24 bg-deb-gold/5 rounded-bl-full transform translate-x-12 -translate-y-12 group-hover:translate-x-8 group-hover:-translate-y-8 transition-transform duration-700" />
	
	<div class="relative z-10">
		<!-- Icon with premium hover effect -->
		<div class="w-16 h-16 rounded-2xl bg-deb-cream flex items-center justify-center mb-8 group-hover:bg-deb-gold/10 transition-all duration-500 group-hover:scale-110 group-hover:rotate-3">
			<svg class="w-8 h-8 text-deb-dark group-hover:text-deb-gold transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[service]} />
		</div>
		
		<!-- Content -->
		<h3 class="text-2xl font-semibold text-deb-dark mb-4 group-hover:text-deb-dark transition-colors duration-300">
			{t(`service.${service}` as keyof typeof import('../../i18n/ui').ui[typeof import('../../i18n/ui').defaultLang])}
		</h3>
		<p class="text-deb-gray-light leading-relaxed mb-6 text-sm">
			{t(`service.${service}.desc` as keyof typeof import('../../i18n/ui').ui[typeof import('../../i18n/ui').defaultLang])}
		</p>
		
		<!-- Link with arrow animation -->
		<span class="inline-flex items-center text-sm font-semibold text-deb-dark group-hover:text-deb-gold transition-all duration-300">
			<span class="relative">
				{t('service.learnMore')}
				<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-deb-gold group-hover:w-full transition-all duration-500" />
			</span>
			<svg class="w-4 h-4 ml-2 transform group-hover:translate-x-2 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
			</svg>
		</span>
	</div>
</a>
