---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import SectionHeader from '../ui/SectionHeader.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Only AFTER images (final results)
const projects = [
	{ id: 1, service: 'peinture', title: lang === 'fr' ? 'Salon contemporain' : 'Salón contemporáneo', image: '/images/after/salon-contemporaneo.webp' },
	{ id: 2, service: 'parquet', title: lang === 'fr' ? 'Parquet chêne massif' : 'Parquet roble macizo', image: '/images/after/parquet-madera.webp' },
	{ id: 3, service: 'carrelage', title: lang === 'fr' ? 'Rénovation d\'entrée' : 'Renovación portal', image: '/images/after/renovacion-portal.webp' },
	{ id: 4, service: 'plomberie', title: lang === 'fr' ? 'Salle de bain marbre' : 'Baño mármol', image: '/images/after/bano-marmol.webp' },
];
---

<section class="py-24 lg:py-32 bg-deb-cream">
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<SectionHeader
			eyebrow={t('projects.eyebrow')}
			title={t('projects.title')}
			description={t('projects.desc')}
		/>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
			{projects.map((project) => (
				<a 
					href={`/${lang}/gallery`}
					class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-deb-gray img-zoom"
				>
					<img 
						src={project.image} 
						alt={project.title}
						class="w-full h-full object-cover img-content"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-deb-dark/80 via-deb-dark/40 to-transparent z-10" />
					<div class="absolute inset-0 flex items-end p-6 z-20">
						<div class="transform translate-y-0 opacity-100 [@media(hover:hover)]:translate-y-4 [@media(hover:hover)]:opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
							<span class="inline-block px-3 py-1 bg-deb-gold/90 text-deb-dark text-xs font-semibold rounded-full mb-3 uppercase tracking-wider">
								{t(`service.${project.service}`)}
							</span>
							<h3 class="text-xl lg:text-2xl font-semibold text-deb-white mb-2">{project.title}</h3>
							<span class="inline-flex items-center text-deb-gold text-sm font-medium">
								{lang === 'fr' ? 'Voir le projet' : 'Ver proyecto'}
								<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
								</svg>
							</span>
						</div>
					</div>
				</a>
			))}
		</div>
		
		<div class="text-center mt-16">
			<a 
				href={`/${lang}/gallery`}
				class="inline-flex items-center px-8 py-4 bg-deb-dark text-deb-white font-medium rounded-full hover:bg-deb-gray transition-all duration-300 hover:shadow-lg"
			>
				{t('projects.cta')}
				<svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
				</svg>
			</a>
		</div>
	</div>
</section>
