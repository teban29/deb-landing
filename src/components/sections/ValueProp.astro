---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const values = [
	{
		title: t('vp.card1.title'),
		desc: t('vp.card1.desc'),
		icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
		number: '01',
	},
	{
		title: t('vp.card2.title'),
		desc: t('vp.card2.desc'),
		icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M12 21l-8-4',
		number: '02',
	},
	{
		title: t('vp.card3.title'),
		desc: t('vp.card3.desc'),
		icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z',
		number: '03',
	},
];
---

<section class="py-24 lg:py-32 bg-deb-cream relative overflow-hidden">
	<!-- Decorative background element -->
	<div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-deb-border to-transparent" />
	
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
			<!-- Left side - Section header -->
			<div class="lg:col-span-4">
				<div class="lg:sticky lg:top-32">
					<div class="flex items-center gap-3 mb-6">
						<span class="w-8 h-[2px] bg-deb-gold rounded-full"></span>
						<span class="text-deb-gold text-sm font-semibold tracking-[0.2em] uppercase">{t('vp.title')}</span>
					</div>
					<h2 class="text-4xl lg:text-5xl font-bold text-deb-dark leading-tight mb-6">
						{lang === 'fr' ? "Ce qui nous" : "Lo que nos"}
						<span class="text-deb-gold block">{lang === 'fr' ? "définit" : "define"}</span>
					</h2>
					<p class="text-deb-gray-light leading-relaxed">
						{lang === 'fr' 
							? "Chaque projet est une promesse de qualité et d'excellence. Nous ne faisons pas de compromis sur les matériaux ni sur la finition."
							: "Cada proyecto es una promesa de calidad y excelencia. No hacemos compromisos en materiales ni en acabados."
						}
					</p>
				</div>
			</div>
			
			<!-- Right side - Cards -->
			<div class="lg:col-span-8 space-y-6">
				{values.map((value, index) => (
					<div class="group relative bg-deb-white rounded-2xl p-8 lg:p-10 border border-deb-border/50 hover:border-deb-gold/30 transition-all duration-700 hover-lift overflow-hidden">
						<!-- Large background number -->
						<span class="absolute top-6 right-8 text-6xl font-bold text-deb-dark/[0.03] group-hover:text-deb-gold/10 transition-colors duration-700 select-none">
							{value.number}
						</span>
						
						<div class="relative z-10 flex flex-col sm:flex-row gap-6 sm:gap-8 items-start">
							<!-- Icon -->
							<div class="w-14 h-14 rounded-2xl bg-deb-cream flex items-center justify-center flex-shrink-0 group-hover:bg-deb-gold/10 transition-all duration-500 group-hover:scale-110">
								<svg class="w-7 h-7 text-deb-dark group-hover:text-deb-gold transition-colors duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
								</svg>
							</div>
							
							<!-- Content -->
							<div class="flex-1">
								<h3 class="text-xl font-semibold text-deb-dark mb-3 group-hover:text-deb-dark transition-colors">
									{value.title}
								</h3>
								<p class="text-deb-gray-light leading-relaxed text-sm">
									{value.desc}
								</p>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
