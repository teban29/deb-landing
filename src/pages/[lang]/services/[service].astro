---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import CTABanner from '../../../components/sections/CTABanner.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const serviceDetails: Record<string, any> = {
	electricite: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
		process: ['Diagnostic complet', 'Étude et devis', 'Installation aux normes', 'Tests et validation'],
		benefits: ['Conformité NFC 15-100', 'Matériel certifié', 'Garantie décennale', 'Intervention urgente 24/7'],
	},
	plomberie: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06 1.06l1.591-1.591a.75.75 0 00-1.061-1.06l-1.59 1.591z"/>',
		process: ['Inspection complète', 'Plan d\'intervention', 'Travaux et remplacement', 'Tests d\'étanchéité'],
		benefits: ['Installation normée', 'Matériel premium', 'Dépannage express', 'Garantie pièces et main d\'œuvre'],
	},
	carrelage: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>',
		process: ['Mesures précises', 'Préparation du support', 'Pose et coupe', 'Finition et jointoiement'],
		benefits: ['Pose garantie 10 ans', 'Large choix de matériaux', 'Découpe sur mesure', 'Conseil design inclus'],
	},
	parquet: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.375 6h17.25M3.375 12h17.25M3.375 18h17.25"/>',
		process: ['Évaluation de l\'existant', 'Préparation du support', 'Pose ou rénovation', 'Finition et vitrification'],
		benefits: ['Bois certifié PEFC', 'Pose flottante ou collée', 'Vitrification écologique', 'Entretien conseillé'],
	},
	peinture: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.077-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>',
		process: ['Préparation des surfaces', 'Protection et masquage', 'Application et finitions', 'Nettoyage et remise en état'],
		benefits: ['Peintures sans COV', 'Large gamme de couleurs', 'Finitions personnalisables', 'Garantie anti-écaillage'],
	},
	poncage: {
		icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>',
		process: ['Évaluation de l\'état', 'Ponçage professionnel', 'Réparations si besoin', 'Protection finale'],
		benefits: ['Équipement industriel', 'Récupération de poussière', 'Résultat lisse et uniforme', 'Préparation peinture incluse'],
	},
};

export function getStaticPaths() {
	return [
		{ params: { lang: 'fr', service: 'electricite' } },
		{ params: { lang: 'fr', service: 'plomberie' } },
		{ params: { lang: 'fr', service: 'carrelage' } },
		{ params: { lang: 'fr', service: 'parquet' } },
		{ params: { lang: 'fr', service: 'peinture' } },
		{ params: { lang: 'fr', service: 'poncage' } },
		{ params: { lang: 'es', service: 'electricite' } },
		{ params: { lang: 'es', service: 'plomberie' } },
		{ params: { lang: 'es', service: 'carrelage' } },
		{ params: { lang: 'es', service: 'parquet' } },
		{ params: { lang: 'es', service: 'peinture' } },
		{ params: { lang: 'es', service: 'poncage' } },
	];
}

const { service } = Astro.params;
const detail = serviceDetails[service as string] || serviceDetails.electricite;
---

<Layout title={t(`service.${service}` as keyof typeof import('../../../i18n/ui').ui[typeof import('../../../i18n/ui').defaultLang])}>
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
			<div class="flex items-center gap-3 mb-6">
				<a href={`/${lang}/services`} class="text-deb-white/60 hover:text-deb-gold transition-colors text-sm">
					← {t('nav.services')}
				</a>
			</div>
			<div class="flex items-start gap-6">
				<div class="w-20 h-20 rounded-2xl bg-deb-gold/10 flex items-center justify-center flex-shrink-0">
					<svg class="w-10 h-10 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={detail.icon} />
				</div>
				<div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight">
						{t(`service.${service}` as keyof typeof import('../../../i18n/ui').ui[typeof import('../../../i18n/ui').defaultLang])}
					</h1>
					<p class="text-lg text-deb-white/60 mt-4 max-w-2xl">
						{t(`service.${service}.desc` as keyof typeof import('../../../i18n/ui').ui[typeof import('../../../i18n/ui').defaultLang])}
					</p>
				</div>
			</div>
		</div>
	</section>
	
	<!-- Process -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
					{t('serviceDetail.process')}
				</span>
				<h2 class="text-3xl sm:text-4xl font-semibold text-deb-dark tracking-tight">
					{t('serviceDetail.process')}
					</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				{detail.process.map((step: string, index: number) => (
					<div class="relative">
						<div class="bg-deb-white rounded-2xl p-8 border border-deb-light-gray/50 h-full">
							<span class="text-5xl font-bold text-deb-gold/20">
								0{index + 1}
							</span>
							<h3 class="text-lg font-semibold text-deb-dark mt-4">{step}</h3>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
	
	<!-- Benefits -->
	<section class="py-24 lg:py-32 bg-deb-white">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
					{t('serviceDetail.benefits')}
				</span>
				<h2 class="text-3xl sm:text-4xl font-semibold text-deb-dark tracking-tight">
					{t('serviceDetail.benefits')}
					</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{detail.benefits.map((benefit: string) => (
					<div class="flex items-start gap-4 bg-deb-cream rounded-2xl p-6">
						<div class="w-10 h-10 rounded-full bg-deb-gold/10 flex items-center justify-center flex-shrink-0">
							<svg class="w-5 h-5 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
							</svg>
						</div>
						<p class="text-deb-dark font-medium">{benefit}</p>
					</div>
				))}
			</div>
		</div>
	</section>
	
	<!-- CTA -->
	<section class="py-20 lg:py-24 bg-deb-dark">
		<div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
			<h2 class="text-3xl sm:text-4xl font-semibold text-deb-white tracking-tight mb-6">
				{t('serviceDetail.cta')}
			</h2>
			<a 
				href={`/${lang}/contact`}
				class="inline-flex items-center px-10 py-5 bg-deb-gold text-deb-dark font-semibold rounded-lg hover:bg-deb-gold/90 transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
			>
				{t('contact.whatsapp.button')}
				<svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
				</svg>
			</a>
		</div>
	</section>
</Layout>
