---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nuestras Realizaciones">
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				D.E.B TOUT CORPS
			</span>
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight mb-6">
				Nuestras Realizaciones
			</h1>
			<p class="text-lg text-deb-white/60 max-w-2xl mx-auto">
				Descubra nuestros proyectos recientes y déjese inspirar para su propia transformación.
			</p>
		</div>
	</section>
	
	<!-- Gallery -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<!-- Filters -->
			<div class="flex flex-wrap justify-center gap-3 mb-12">
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-gold text-deb-dark">Todos</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Electricidad</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Fontanería</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Alicatado</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Parquet</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Pintura</button>
				<button class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50">Lijado</button>
			</div>
			
			<!-- Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{[
					{ title: 'Salón contemporáneo', category: 'Pintura' },
					{ title: 'Parquet roble macizo', category: 'Parquet' },
					{ title: 'Baño de diseño', category: 'Alicatado' },
					{ title: 'Instalación completa', category: 'Electricidad' },
					{ title: 'Dormitorio principal', category: 'Pintura' },
					{ title: 'Cocina moderna', category: 'Fontanería' },
					{ title: 'Restauración parquet', category: 'Lijado' },
					{ title: 'Terraza exterior', category: 'Alicatado' },
				].map((project) => (
					<div class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-deb-gray cursor-pointer">
						<div class="absolute inset-0 bg-deb-dark/40 group-hover:bg-deb-dark/30 transition-colors duration-500 z-10" />
						<div class="absolute inset-0 flex items-end p-6 z-20">
							<div class="transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
								<span class="inline-block px-3 py-1 bg-deb-gold/90 text-deb-dark text-xs font-semibold rounded-full mb-2 uppercase tracking-wider">{project.category}</span>
								<h3 class="text-lg font-semibold text-deb-white">{project.title}</h3>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
