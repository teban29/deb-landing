---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Contacto">
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				D.E.B TOUT CORPS
			</span>
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight mb-6">
				Contáctenos
			</h1>
			<p class="text-lg text-deb-white/60 max-w-2xl mx-auto">
				¿Listo para iniciar su proyecto? Estamos aquí para acompañarle en cada paso.
			</p>
		</div>
	</section>
	
	<!-- Contact Section -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
				<!-- Form -->
				<div class="bg-deb-white rounded-2xl p-8 lg:p-10 border border-deb-light-gray/50">
					<form class="space-y-6" action="#" method="POST">
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<div>
								<label for="name" class="block text-sm font-medium text-deb-dark mb-2">Nombre completo *</label>
								<input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-deb-light-gray bg-deb-cream text-deb-dark focus:outline-none focus:ring-2 focus:ring-deb-gold/50 focus:border-deb-gold transition-all duration-200" placeholder="Nombre completo" />
							</div>
							<div>
								<label for="email" class="block text-sm font-medium text-deb-dark mb-2">Email *</label>
								<input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-deb-light-gray bg-deb-cream text-deb-dark focus:outline-none focus:ring-2 focus:ring-deb-gold/50 focus:border-deb-gold transition-all duration-200" placeholder="email@ejemplo.com" />
							</div>
						</div>
						
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<div>
								<label for="phone" class="block text-sm font-medium text-deb-dark mb-2">Teléfono</label>
								<input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-deb-light-gray bg-deb-cream text-deb-dark focus:outline-none focus:ring-2 focus:ring-deb-gold/50 focus:border-deb-gold transition-all duration-200" placeholder="+33 1 23 45 67 89" />
							</div>
							<div>
								<label for="service" class="block text-sm font-medium text-deb-dark mb-2">Servicio deseado</label>
								<select id="service" name="service" class="w-full px-4 py-3 rounded-lg border border-deb-light-gray bg-deb-cream text-deb-dark focus:outline-none focus:ring-2 focus:ring-deb-gold/50 focus:border-deb-gold transition-all duration-200">
									<option value="">Seleccione un servicio</option>
									<option value="electricite">Electricidad</option>
									<option value="plomberie">Fontanería</option>
									<option value="carrelage">Alicatado</option>
									<option value="parquet">Parquet</option>
									<option value="peinture">Pintura</option>
									<option value="poncage">Lijado</option>
								</select>
							</div>
						</div>
						
						<div>
							<label for="message" class="block text-sm font-medium text-deb-dark mb-2">Su mensaje *</label>
							<textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-deb-light-gray bg-deb-cream text-deb-dark focus:outline-none focus:ring-2 focus:ring-deb-gold/50 focus:border-deb-gold transition-all duration-200 resize-none" placeholder="Su mensaje"></textarea>
						</div>
						
						<button type="submit" class="w-full px-8 py-4 bg-deb-dark text-deb-white font-semibold rounded-lg hover:bg-deb-gray transition-all duration-300 hover:shadow-lg">
							Enviar solicitud
						</button>
					</form>
				</div>
				
				<!-- Contact Info -->
				<div class="space-y-8">
					<div class="bg-deb-white rounded-2xl p-8 border border-deb-light-gray/50">
						<h3 class="text-xl font-semibold text-deb-dark mb-6">Información de contacto</h3>
						<ul class="space-y-6">
							<li class="flex items-start gap-4">
								<div class="w-12 h-12 rounded-xl bg-deb-gold/10 flex items-center justify-center flex-shrink-0">
									<svg class="w-6 h-6 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
								</div>
								<div>
									<p class="text-sm text-deb-gray mb-1">Teléfono</p>
									<p class="text-deb-dark font-medium">+33 1 23 45 67 89</p>
								</div>
							</li>
							<li class="flex items-start gap-4">
								<div class="w-12 h-12 rounded-xl bg-deb-gold/10 flex items-center justify-center flex-shrink-0">
									<svg class="w-6 h-6 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
								</div>
								<div>
									<p class="text-sm text-deb-gray mb-1">Email</p>
									<p class="text-deb-dark font-medium">contact@deb-toutcorps.fr</p>
								</div>
							</li>
							<li class="flex items-start gap-4">
								<div class="w-12 h-12 rounded-xl bg-deb-gold/10 flex items-center justify-center flex-shrink-0">
									<svg class="w-6 h-6 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								</div>
								<div>
									<p class="text-sm text-deb-gray mb-1">Horario</p>
									<p class="text-deb-dark font-medium">Lun - Vie: 8:00 - 18:00</p>
								</div>
							</li>
						</ul>
					</div>
					
					<div class="bg-green-50 rounded-2xl p-8 border border-green-100">
						<div class="flex items-start gap-4">
							<div class="w-12 h-12 rounded-xl bg-green-500 flex items-center justify-center flex-shrink-0">
								<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							</div>
							<div>
								<h3 class="text-lg font-semibold text-deb-dark mb-2">O contáctenos por WhatsApp</h3>
								<p class="text-deb-gray text-sm mb-4">Para una respuesta rápida, envíenos un mensaje directamente por WhatsApp.</p>
								<a href="https://wa.me/33123456789" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 bg-green-500 text-white font-medium rounded-lg hover:bg-green-600 transition-all duration-300">
									Escribir por WhatsApp
									<svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
								</a>
							</div>
						</div>
					</div>
					
					<div class="bg-deb-white rounded-2xl p-8 border border-deb-light-gray/50">
						<h3 class="text-lg font-semibold text-deb-dark mb-4">Zona de intervención</h3>
						<div class="aspect-video rounded-xl bg-deb-cream flex items-center justify-center">
							<div class="text-center p-6">
								<svg class="w-12 h-12 text-deb-gold/40 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
								<p class="text-deb-gray text-sm">Francia</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
