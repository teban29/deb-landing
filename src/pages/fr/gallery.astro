---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categories = [
	{ id: 'all', label: t('gallery.category.all') },
	{ id: 'electricite', label: t('gallery.category.electricite') },
	{ id: 'plomberie', label: t('gallery.category.plomberie') },
	{ id: 'carrelage', label: t('gallery.category.carrelage') },
	{ id: 'parquet', label: t('gallery.category.parquet') },
	{ id: 'peinture', label: t('gallery.category.peinture') },
	{ id: 'poncage', label: t('gallery.category.poncage') },
];

const projects = [
	{ id: 1, category: 'peinture', title: lang === 'fr' ? 'Salon contemporain' : 'Salón contemporáneo' },
	{ id: 2, category: 'parquet', title: lang === 'fr' ? 'Parquet chêne massif' : 'Parquet roble macizo' },
	{ id: 3, category: 'carrelage', title: lang === 'fr' ? 'Salle de bain design' : 'Baño de diseño' },
	{ id: 4, category: 'electricite', title: lang === 'fr' ? 'Installation complète' : 'Instalación completa' },
	{ id: 5, category: 'peinture', title: lang === 'fr' ? 'Chambre parentale' : 'Dormitorio principal' },
	{ id: 6, category: 'plomberie', title: lang === 'fr' ? 'Cuisine moderne' : 'Cocina moderna' },
	{ id: 7, category: 'poncage', title: lang === 'fr' ? 'Restauration parquet' : 'Restauración parquet' },
	{ id: 8, category: 'carrelage', title: lang === 'fr' ? 'Terrasse extérieure' : 'Terraza exterior' },
];
---

<Layout title={t('gallery.title')}>
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				D.E.B TOUT CORPS
			</span>
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight mb-6">
				{t('gallery.title')}
			</h1>
			<p class="text-lg text-deb-white/60 max-w-2xl mx-auto">
				{t('gallery.subtitle')}
			</p>
		</div>
	</section>
	
	<!-- Gallery -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<!-- Filters -->
			<div class="flex flex-wrap justify-center gap-3 mb-12">
				{categories.map((cat) => (
					<button 
						class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 bg-deb-white text-deb-dark hover:bg-deb-gold hover:text-deb-dark border border-deb-light-gray/50"
						data-category={cat.id}
					>
						{cat.label}
					</button>
				))}
			</div>
			
			<!-- Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{projects.map((project) => (
					<div 
						class="group relative aspect-[4/3] rounded-2xl overflow-hidden bg-deb-gray cursor-pointer"
						data-project-category={project.category}
					>
						<div class="absolute inset-0 bg-deb-dark/40 group-hover:bg-deb-dark/30 transition-colors duration-500 z-10" />
						<div class="absolute inset-0 flex items-end p-6 z-20">
							<div class="transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
								<span class="inline-block px-3 py-1 bg-deb-gold/90 text-deb-dark text-xs font-semibold rounded-full mb-2 uppercase tracking-wider">
									{t(`gallery.category.${project.category}`)}
								</span>
								<h3 class="text-lg font-semibold text-deb-white">{project.title}</h3>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
