---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Only AFTER images (final results)
const projects = [
	{ id: 1, category: 'peinture', title: lang === 'fr' ? 'Salon contemporain' : 'Salón contemporáneo', image: '/images/after/salon-contemporaneo.webp' },
	{ id: 2, category: 'parquet', title: lang === 'fr' ? 'Escalier résidentiel' : 'Escalera residencial', image: '/images/after/escaleras-residenciales.webp' },
	{ id: 3, category: 'plomberie', title: lang === 'fr' ? 'Salle de bain marbre' : 'Baño mármol', image: '/images/after/bano-marmol.webp' },
	{ id: 4, category: 'peinture', title: lang === 'fr' ? 'Moulures contemporaines' : 'Molduras contemporáneas', image: '/images/after/molduras-contemporaneas.webp' },
	{ id: 5, category: 'parquet', title: lang === 'fr' ? 'Parquet bois massif' : 'Parquet madera', image: '/images/after/parquet-madera.webp' },
	{ id: 6, category: 'peinture', title: lang === 'fr' ? 'Couloir avec moulures' : 'Pasillo con molduras', image: '/images/after/pasillo-molduras.webp' },
	{ id: 7, category: 'carrelage', title: lang === 'fr' ? 'Rénovation d\'entrée' : 'Renovación portal', image: '/images/after/renovacion-portal.webp' },
	{ id: 8, category: 'peinture', title: lang === 'fr' ? 'Escalier et fenêtres' : 'Escalera y ventanas', image: '/images/after/escaleras-ventanas.webp' },
	{ id: 9, category: 'peinture', title: lang === 'fr' ? 'Salon professionnel' : 'Salón profesional', image: '/images/after/salon-profesional.webp' },
	{ id: 10, category: 'peinture', title: lang === 'fr' ? 'Salon seigneurial' : 'Salón señorial', image: '/images/after/salon-senorial.webp' },
];
---

<Layout title={t('gallery.title')}>
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				D.E.B TOUT CORPS
			</span>
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight mb-6">
				{t('gallery.title')}
			</h1>
			<p class="text-lg text-deb-white/60 max-w-2xl mx-auto">
				{t('gallery.subtitle')}
			</p>
		</div>
	</section>
	
	<!-- Gallery -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<!-- Masonry Grid -->
			<div class="masonry-grid">
				{projects.map((project) => (
					<div 
						class="masonry-item group relative rounded-2xl overflow-hidden bg-deb-gray cursor-pointer img-zoom"
						data-project-category={project.category}
					>
						<img 
							src={project.image} 
							alt={project.title}
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-deb-dark/80 via-deb-dark/20 to-transparent opacity-100 [@media(hover:hover)]:opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10" />
						<div class="absolute inset-0 flex items-end p-6 z-20 opacity-100 [@media(hover:hover)]:opacity-0 group-hover:opacity-100 transition-opacity duration-500">
							<div class="transform translate-y-0 [@media(hover:hover)]:translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
								<span class="inline-block px-3 py-1 bg-deb-gold text-deb-dark text-xs font-semibold rounded-full mb-2 uppercase tracking-wider">
									{t(`gallery.category.${project.category}`)}
								</span>
								<h3 class="text-lg font-semibold text-deb-white">{project.title}</h3>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
