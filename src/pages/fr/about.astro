---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('about.title')}>
	<!-- Hero -->
	<section class="relative py-32 lg:py-40 bg-deb-dark overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-deb-dark via-deb-gray to-deb-dark" />
		<div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				D.E.B TOUT CORPS
			</span>
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-deb-white tracking-tight mb-6">
				{t('about.title')}
			</h1>
			<p class="text-lg text-deb-white/60 max-w-2xl mx-auto">
				{t('about.subtitle')}
			</p>
		</div>
	</section>
	
	<!-- Story Section -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
				<div>
					<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
						{lang === 'fr' ? 'Notre Histoire' : 'Nuestra Historia'}
					</span>
					<h2 class="text-3xl sm:text-4xl font-semibold text-deb-dark tracking-tight mb-6">
						{t('about.story.title')}
					</h2>
					<div class="space-y-4 text-deb-gray leading-relaxed">
						<p>{t('about.story.p1')}</p>
						<p>{t('about.story.p2')}</p>
					</div>
				</div>
				
				<div class="relative">
					<div class="aspect-[4/3] rounded-2xl bg-deb-gray/10 overflow-hidden">
						<div class="absolute inset-0 bg-gradient-to-br from-deb-dark/5 to-deb-gold/10" />
						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center p-8">
								<div class="w-32 h-32 mx-auto mb-6 rounded-full bg-deb-gold/20 flex items-center justify-center">
									<span class="text-4xl font-bold text-deb-gold">D.E.B</span>
								</div>
							</div>
						</div>
					</div>
					<div class="absolute -bottom-6 -right-6 w-32 h-32 bg-deb-gold/10 rounded-2xl -z-10" />
				</div>
			</div>
		</div>
	</section>
	
	<!-- Philosophy -->
	<section class="py-24 lg:py-32 bg-deb-white">
		<div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
			<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
				{t('about.philosophy.title')}
			</span>
			<h2 class="text-3xl sm:text-4xl font-semibold text-deb-dark tracking-tight mb-8">
				{t('about.philosophy.title')}
			</h2>
			<p class="text-lg text-deb-gray leading-relaxed">
				{t('about.philosophy.p1')}
			</p>
		</div>
	</section>
	
	<!-- Values -->
	<section class="py-24 lg:py-32 bg-deb-cream">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
					{t('about.values.title')}
				</span>
				<h2 class="text-3xl sm:text-4xl font-semibold text-deb-dark tracking-tight">
					{t('about.values.title')}
				</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{[
					{ title: t('about.value1.title'), desc: t('about.value1.desc'), icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
					{ title: t('about.value2.title'), desc: t('about.value2.desc'), icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
					{ title: t('about.value3.title'), desc: t('about.value3.desc'), icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
				].map((value) => (
					<div class="bg-deb-white rounded-2xl p-8 border border-deb-light-gray/50 text-center">
						<div class="w-16 h-16 mx-auto rounded-xl bg-deb-gold/10 flex items-center justify-center mb-6">
							<svg class="w-8 h-8 text-deb-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-deb-dark mb-3">{value.title}</h3>
						<p class="text-deb-gray leading-relaxed">{value.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Process / Work in Progress -->
	<section class="py-24 lg:py-32 bg-deb-white">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<div class="text-center mb-16">
				<span class="inline-block text-sm font-semibold tracking-widest uppercase text-deb-gold mb-4">
					{t('about.process.eyebrow')}
				</span>
				<h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold text-deb-dark tracking-tight mb-6">
					{t('about.process.title')}
				</h2>
				<p class="text-lg text-deb-gray max-w-2xl mx-auto">
					{t('about.process.subtitle')}
				</p>
			</div>

			<!-- Masonry Grid -->
			<div class="masonry-grid">
				{[
					'/images/before/project-01.webp',
					'/images/before/project-02.webp',
					'/images/before/project-03.webp',
					'/images/before/project-04.webp',
					'/images/before/project-05.webp',
					'/images/before/project-06.webp',
					'/images/before/project-07.webp',
					'/images/before/project-09.webp',
					'/images/before/project-10.webp',
					'/images/before/project-11.webp',
					'/images/before/project-12.webp',
					'/images/before/project-13.webp',
					'/images/before/project-14.webp',
					'/images/before/project-17.webp',
					'/images/before/project-19.webp',
					'/images/before/project-20.webp',
					'/images/before/project-22.webp',
					'/images/before/project-23.webp',
					'/images/before/project-24.webp',
					'/images/before/project-26.webp',
					'/images/before/project-27.webp',
					'/images/before/project-29.webp',
					'/images/before/project-30.webp',
				].map((src, index) => (
					<div class="masonry-item group relative rounded-2xl overflow-hidden bg-deb-gray cursor-pointer img-zoom">
						<img 
							src={src} 
							alt={`Travaux ${index + 1}`}
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-deb-dark/60 via-deb-dark/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10" />
						<div class="absolute inset-0 flex items-end p-5 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
							<div class="transform translate-y-3 group-hover:translate-y-0 transition-transform duration-500">
								<span class="inline-flex items-center gap-2 text-deb-gold text-sm font-medium">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
									</svg>
									{lang === 'fr' ? 'Aperçu chantier' : 'Vista obra'}
								</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
